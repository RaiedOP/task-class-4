if(en&&sl&&lots&&cfg){const pips=Math.abs(en-sl)/cfg.p;const rD=pips*cfg.v*lots;const eP=document.getElementById('cc-pips');const eR=document.getElementById('cc-risk');if(eP)eP.textContent=pips.toFixed(1);if(eR)eR.textContent='$'+rD.toFixed(2);if(aS>0){const pct=rD/aS*100;const eC=document.getElementById('cc-pct');if(eC)eC.textContent=pct.toFixed(2)+'%';const rpE=document.getElementById('t-rp');if(rpE&&!rpE.matches(':focus'))rpE.value=pct.toFixed(2);}show=true;}
else if(en&&sl&&rp&&aS>0&&cfg&&!lots){const rD=aS*rp/100;const pips=Math.abs(en-sl)/cfg.p;if(pips>0){const sug=rD/(pips*cfg.v);const sv=document.getElementById('lot-sv');const sd=document.getElementById('lot-sug');if(sv)sv.textContent=sug.toFixed(2);if(sd)sd.style.display='block';show=true;}}
if(lots){const sd=document.getElementById('lot-sug');if(sd)sd.style.display='none';}
const cb=document.getElementById('calc-box');if(cb)cb.style.display=show?'block':'none';}
function setAddExit(type){['tp','sl','be','manual'].forEach(b=>{const el=document.getElementById('abt-'+b);if(el)el.style.outline=b===type?'2px solid rgba(139,92,246,.7)':'none';});const en=document.getElementById('t-en')?.value;const tp=document.getElementById('t-tp')?.value;const sl=document.getElementById('t-sl')?.value;const exEl=document.getElementById('t-ex');const rE=document.getElementById('t-re');if(type==='tp'){if(exEl)exEl.value=tp||'';if(rE)rE.value='Win';}else if(type==='sl'){if(exEl)exEl.value=sl||'';if(rE)rE.value='Loss';}else if(type==='be'){if(exEl)exEl.value=en||'';if(rE)rE.value='Break Even';}else{if(exEl){exEl.value='';exEl.focus();}}calcPnL();}
function calcPnL(){const inst=(document.getElementById('t-in')?.value||'').trim().toUpperCase();const dir=document.getElementById('t-di')?.value||'Buy';const en=parseFloat(document.getElementById('t-en')?.value);const ex=parseFloat(document.getElementById('t-ex')?.value);const lots=parseFloat(document.getElementById('t-lt')?.value);if(!en||!ex)return;const cfg=iCfg(inst);const isBuy=dir==='Buy';const tp=parseFloat(document.getElementById('t-tp')?.value)||null;const sl=parseFloat(document.getElementById('t-sl')?.value)||null;const diff=isBuy?ex-en:en-ex;if(lots){const pnl=diff/cfg.p*cfg.v*lots;const pE=document.getElementById('t-pn');if(pE)pE.value=pnl.toFixed(2);}const rE=document.getElementById('t-re');if(rE){if(tp&&((isBuy&&ex>=tp)||(!isBuy&&ex<=tp)))rE.value='Win';else if(sl&&((isBuy&&ex<=sl)||(!isBuy&&ex>=sl)))rE.value='Loss';else rE.value=diff>0?'Win':diff<0?'Loss':'Break Even';}}
function useSug(){const v=document.getElementById('lot-sv')?.textContent;if(v){const el=document.getElementById('t-lt');if(el){el.value=v;autoCalc();}}}

