    document.querySelectorAll('.kv').forEach(el=>{
      const orig=el.textContent.trim();
      const m=orig.match(/^([+\-$€£%]*)(\d+\.?\d*)(.*)/);
      if(!m)return;
      const pre=m[1],num=parseFloat(m[2]),suf=m[3];
      if(isNaN(num)||num<1)return;
      let s=null;const dur=700;
      const fmt=num%1===0?v=>Math.round(v):v=>v.toFixed(num<10?2:1);
      const step=ts=>{if(!s)s=ts;const p=Math.min((ts-s)/dur,1);const e=1-Math.pow(1-p,3);el.textContent=pre+fmt(num*e)+suf;if(p<1)requestAnimationFrame(step);else el.textContent=orig;};
      requestAnimationFrame(step);
    });
  },100);
}

