
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>EdgeVaultX</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/three@0.157.0/build/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/gsap.min.js"></script>
<style>
/* ═══════════════════════════════════════════════════
   EDGEVAULTX — PREMIUM DESIGN SYSTEM
   ═══════════════════════════════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0}
html{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
::selection{background:rgba(139,92,246,.3);color:#F1F5F9}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(139,92,246,.25);border-radius:2px}
::-webkit-scrollbar-thumb:hover{background:rgba(139,92,246,.4)}
:root{
  --bg:#04060E;--bg2:#070B16;
  --s1:rgba(7,10,22,.85);--card:rgba(12,18,35,.82);--card2:rgba(16,24,44,.88);
  --acc:#8B5CF6;--acc2:#A78BFA;--acc3:#C4B5FD;
  --cyn:#22D3EE;--cyn2:#67E8F9;--grn:#34D399;--grn2:#6EE7B7;
  --red:#FB7185;--amb:#FBBF24;
  --txt:#F1F5F9;--t2:#94A3B8;--t3:#64748B;--t4:#374151;--t5:#1E293B;
  --bdr:rgba(255,255,255,.055);--bdr2:rgba(139,92,246,.25);--bdr3:rgba(139,92,246,.4);
  --font:'Inter',system-ui,-apple-system,sans-serif;
  --font-display:'Space Grotesk','Inter',sans-serif;
  --r-sm:6px;--r-md:10px;--r-lg:14px;--r-xl:20px;
  --ease-spring:cubic-bezier(.34,1.56,.64,1);
  --ease-out:cubic-bezier(.22,1,.36,1);
  --shadow-md:0 8px 32px rgba(0,0,0,.5),0 2px 8px rgba(0,0,0,.3);
  --shadow-lg:0 20px 60px rgba(0,0,0,.6),0 4px 16px rgba(0,0,0,.4);
  --shadow-acc:0 0 0 1px rgba(139,92,246,.2),0 8px 32px rgba(139,92,246,.15);
  --scene-rgb:139,92,246;--scene-tint:#8B5CF699;--scene-tint-soft:rgba(139,92,246,.06);
}
#app{background:var(--bg);color:var(--txt);min-height:100svh;display:flex;font-family:var(--font);font-size:13px;line-height:1.5;position:relative;overflow:hidden}
#three-bg{position:fixed;inset:0;pointer-events:none;z-index:0}
#three-bg canvas{position:absolute;inset:0;width:100%!important;height:100%!important}
#cursor-orb{position:fixed;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(var(--scene-rgb),.055) 0%,transparent 70%);pointer-events:none;z-index:1;transform:translate(-50%,-50%);transition:background 1s ease;will-change:transform}

/* ── SIDEBAR ── */
.sb{width:216px;min-width:216px;background:rgba(5,8,18,.8);backdrop-filter:blur(28px) saturate(1.6) brightness(1.04);-webkit-backdrop-filter:blur(28px) saturate(1.6) brightness(1.04);border-right:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;position:relative;z-index:2;flex-shrink:0;overflow:hidden;transition:background .8s,border-color .8s}
.sb::before{content:'';position:absolute;top:0;left:0;bottom:0;width:1px;background:linear-gradient(180deg,transparent,rgba(var(--scene-rgb),.55) 35%,rgba(34,211,238,.3) 65%,transparent);opacity:.7;pointer-events:none;transition:opacity .8s}
.sb::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at -10% 45%,rgba(var(--scene-rgb),.07) 0%,transparent 60%);pointer-events:none;transition:background .8s}
#sb-indicator{position:absolute;left:0;width:2px;height:32px;background:linear-gradient(180deg,transparent,var(--acc),var(--cyn),transparent);box-shadow:0 0 10px var(--acc),0 0 20px rgba(139,92,246,.35);border-radius:0 1px 1px 0;transition:top .35s var(--ease-spring);pointer-events:none;z-index:3}
.sb-top{padding:20px 15px 12px}
.logo{font-family:var(--font-display);font-size:17px;font-weight:700;display:flex;align-items:center;gap:8px;margin-bottom:1px;background:linear-gradient(135deg,#C4B5FD 0%,#A78BFA 40%,#22D3EE 80%,#A78BFA 100%);background-size:300% 300%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:logoGrad 6s ease infinite;filter:drop-shadow(0 0 14px rgba(139,92,246,.3))}
@keyframes logoGrad{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
.brand{font-size:9px;color:var(--t4);letter-spacing:.1em;margin-bottom:14px;text-transform:uppercase;font-weight:500}
.sb-acct{display:flex;align-items:center;gap:9px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.06);border-radius:var(--r-lg);padding:9px 11px;cursor:pointer;transition:all .2s var(--ease-out);position:relative;overflow:hidden}
.sb-acct::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(var(--scene-rgb),.08),transparent);opacity:0;transition:opacity .2s}
.sb-acct:hover{border-color:rgba(var(--scene-rgb),.22);background:rgba(var(--scene-rgb),.07)}
.sb-acct:hover::after{opacity:1}
.sb-aorb{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;box-shadow:0 0 12px rgba(var(--scene-rgb),.35)}
.sb-aname{font-size:12px;color:var(--txt);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.sb-asize{font-size:9px;color:var(--t3)}
.ns{padding:16px 15px 4px;font-size:9px;letter-spacing:.14em;color:var(--t4);text-transform:uppercase;font-weight:600}
.ni{display:flex;align-items:center;gap:9px;padding:9px 15px;cursor:pointer;color:var(--t3);border-left:2px solid transparent;font-size:12px;transition:color .18s,background .18s;user-select:none;position:relative;overflow:hidden}
.ni::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(var(--scene-rgb),.1),transparent 70%);transform:translateX(-100%);transition:transform .4s var(--ease-out)}
.ni:hover{color:var(--t2)}
.ni:hover::before{transform:translateX(0)}
.ni.on{color:var(--acc2);border-left-color:transparent;background:rgba(var(--scene-rgb),.08)}
.ni.on::before{transform:translateX(0);background:linear-gradient(90deg,rgba(var(--scene-rgb),.14),transparent 70%)}
.ni i{font-size:15px;width:17px;flex-shrink:0;transition:transform .2s var(--ease-spring),color .18s}
.ni:hover i{transform:scale(1.12)}
.ni.on i{color:var(--acc);transform:scale(1.08)}
.sb-foot{margin-top:auto;padding:12px 15px;border-top:1px solid rgba(255,255,255,.04);font-size:10px;color:var(--t4);line-height:2}

/* ── TOPBAR ── */
.main{flex:1;overflow-y:auto;display:flex;flex-direction:column;z-index:1;min-width:0}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;border-bottom:1px solid rgba(255,255,255,.04);background:rgba(4,6,14,.62);backdrop-filter:blur(32px) saturate(1.7);-webkit-backdrop-filter:blur(32px) saturate(1.7);position:sticky;top:0;z-index:10;flex-shrink:0;transition:background .8s}
.topbar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--acc),var(--cyn),var(--acc),transparent);background-size:300% 100%;animation:hLine 5s linear infinite;opacity:.4}
@keyframes hLine{0%{background-position:100% 0}100%{background-position:-200% 0}}
.tb-t{font-size:15px;font-weight:700;font-family:var(--font-display);color:var(--txt);letter-spacing:-.015em}
.tb-r{display:flex;align-items:center;gap:10px}
.acct-lbl{font-size:10px;color:var(--t3);max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* ── BUTTONS ── */
.btn{background:var(--acc);color:#fff;border:none;padding:7px 16px;border-radius:var(--r-lg);cursor:pointer;font-size:12px;font-weight:600;font-family:var(--font);transition:all .15s var(--ease-out);flex-shrink:0;position:relative;overflow:hidden}
.btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.18),transparent);opacity:0;transition:opacity .15s}
.btn:hover{background:#7C3AED;box-shadow:0 0 24px rgba(139,92,246,.45),0 4px 12px rgba(0,0,0,.3);transform:translateY(-1px)}
.btn:hover::before{opacity:1}
.btn:active{transform:translateY(1px) scale(.97)}
.btn:disabled{opacity:.35;cursor:default}
.btn-g{background:rgba(255,255,255,.04);color:var(--txt);border:1px solid rgba(255,255,255,.08);padding:6px 14px;border-radius:var(--r-lg);cursor:pointer;font-size:12px;font-family:var(--font);transition:all .15s var(--ease-out);flex-shrink:0}
.btn-g:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.14);transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.3)}
.btn-g:active{transform:translateY(0) scale(.97)}
.orb{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;cursor:pointer;border:1.5px solid rgba(255,255,255,.1);transition:all .2s var(--ease-out);color:#fff;flex-shrink:0;background:rgba(255,255,255,.04)}
.orb:hover{border-color:var(--acc);box-shadow:0 0 18px rgba(139,92,246,.35);transform:scale(1.06)}

/* ── CONTENT ── */
.content{padding:22px 24px;flex:1}
.pg{display:none}.pg.on{display:block}

/* ── CARDS ── */
.card{background:rgba(8,13,28,.78);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);border:1px solid rgba(255,255,255,.058);border-radius:var(--r-xl);padding:18px;margin-bottom:14px;transform-style:preserve-3d;will-change:transform;transition:transform .2s var(--ease-out),box-shadow .2s ease,border-color .3s;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.09),transparent);pointer-events:none}
.card::after{content:'';position:absolute;width:300px;height:300px;background:radial-gradient(circle,rgba(var(--scene-rgb),.09),transparent 70%);border-radius:50%;pointer-events:none;opacity:0;transition:opacity .3s;transform:translate(-50%,-50%);left:var(--cx,50%);top:var(--cy,50%)}
.card:hover{border-color:rgba(var(--scene-rgb),.2);box-shadow:0 24px 64px rgba(0,0,0,.55),0 0 0 1px rgba(var(--scene-rgb),.1),inset 0 1px 0 rgba(255,255,255,.06)}
.card:hover::after{opacity:1}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
.kpi{background:rgba(7,11,24,.82);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.055);border-radius:var(--r-xl);padding:16px 18px;transition:all .2s var(--ease-out);position:relative;overflow:hidden;cursor:default}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.07),transparent)}
.kpi:hover{border-color:rgba(var(--scene-rgb),.22);transform:translateY(-2px);box-shadow:var(--shadow-acc)}
.kl{font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:7px;font-weight:600}
.kv{font-size:24px;font-weight:800;line-height:1;color:var(--txt);font-family:var(--font-display);letter-spacing:-.02em}
.ks{font-size:10px;color:var(--t3);margin-top:5px}
.kv.g{color:var(--grn)}.kv.r{color:var(--red)}.kv.y{color:var(--amb)}.kv.c{color:var(--cyn)}.kv.p{color:var(--acc2)}

/* ── TAGS ── */
.tag{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:600;letter-spacing:.02em}
.tg{background:rgba(52,211,153,.1);color:var(--grn);border:1px solid rgba(52,211,153,.2)}
.tr{background:rgba(251,113,133,.1);color:var(--red);border:1px solid rgba(251,113,133,.2)}
.tb{background:rgba(139,92,246,.1);color:var(--acc2);border:1px solid rgba(139,92,246,.2)}
.ty{background:rgba(251,191,36,.1);color:var(--amb);border:1px solid rgba(251,191,36,.2)}
.tn{background:rgba(148,163,184,.06);color:var(--t2);border:1px solid rgba(148,163,184,.12)}
.tc{background:rgba(34,211,238,.08);color:var(--cyn);border:1px solid rgba(34,211,238,.18)}
.ch{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.ct{font-size:13px;font-weight:700;color:var(--acc2);font-family:var(--font-display);letter-spacing:-.01em}

/* ── TABLE ── */
table{width:100%;border-collapse:collapse;font-size:11px}
th{text-align:left;color:var(--t3);font-weight:600;padding:7px 9px;border-bottom:1px solid rgba(255,255,255,.04);font-size:9px;text-transform:uppercase;letter-spacing:.1em;white-space:nowrap}
td{padding:10px 9px;border-bottom:1px solid rgba(255,255,255,.025);vertical-align:middle;color:var(--t2)}
tr:hover td{background:rgba(var(--scene-rgb),.035)}
#log-body tr{transition:transform .15s ease,box-shadow .15s ease,background .15s}
#log-body tr:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(var(--scene-rgb),.12);position:relative;z-index:1}

/* ── FORMS ── */
.fg{margin-bottom:12px}
.fl{display:block;font-size:9px;color:var(--t3);margin-bottom:5px;text-transform:uppercase;letter-spacing:.1em;font-weight:600}
.fi{width:100%;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:var(--r-md);padding:9px 12px;color:var(--txt);font-size:12px;font-family:var(--font);outline:none;transition:all .18s}
.fi:focus{border-color:rgba(139,92,246,.45);background:rgba(139,92,246,.04);box-shadow:0 0 0 3px rgba(139,92,246,.09)}
.fi::placeholder{color:var(--t4)}.fi[readonly]{color:var(--acc2)}
.fs{width:100%;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:var(--r-md);padding:9px 12px;color:var(--txt);font-size:12px;font-family:var(--font);outline:none;cursor:pointer;transition:all .18s}
.fs:focus{border-color:rgba(139,92,246,.45);box-shadow:0 0 0 3px rgba(139,92,246,.09)}
.fs option{background:#0A1020;color:var(--txt)}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}

/* ── PROGRESS ── */
.pb{height:3px;background:rgba(255,255,255,.04);border-radius:2px;overflow:hidden;margin-top:4px}
.pf{height:3px;border-radius:2px;transition:width .65s var(--ease-out)}
.dvd{height:1px;background:rgba(255,255,255,.05);margin:14px 0}

/* ── EMPTY STATES ── */
.empty{text-align:center;padding:64px 20px;color:var(--t3)}
.empty i{font-size:44px;display:block;margin-bottom:14px;opacity:.18;color:var(--acc)}
.empty h3{font-size:17px;color:var(--t2);font-weight:700;margin-bottom:8px;font-family:var(--font-display)}
.empty p{font-size:12px;line-height:1.75;color:var(--t3);max-width:260px;margin:0 auto}

/* ── MISC ── */
.sb-bar{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.sb-lbl{width:70px;font-size:11px;color:var(--t2)}
.sb-trk{flex:1;background:rgba(255,255,255,.05);border-radius:2px;height:3px}
.sb-fil{height:3px;border-radius:2px}
.sb-val{font-size:11px;min-width:30px;text-align:right;color:var(--t2)}
.gr-btn{display:inline-flex;align-items:center;justify-content:center;padding:5px 12px;border-radius:20px;cursor:pointer;font-size:11px;font-weight:500;border:1px solid rgba(255,255,255,.08);background:transparent;color:var(--t3);margin-right:4px;transition:all .15s}
.gr-btn.on{border-color:var(--acc);background:rgba(139,92,246,.14);color:var(--acc2)}
.em-tag,.vl-tag{display:inline-flex;padding:4px 10px;border-radius:20px;cursor:pointer;font-size:11px;margin:0 3px 5px 0;border:1px solid;transition:all .15s;user-select:none;color:var(--t2)}
.em-tag{background:rgba(255,255,255,.03);border-color:rgba(255,255,255,.06)}
.em-tag.on{background:rgba(139,92,246,.12);color:var(--acc2);border-color:rgba(139,92,246,.28)}
.vl-tag{background:rgba(251,113,133,.05);border-color:rgba(251,113,133,.1)}
.vl-tag.on{background:rgba(251,113,133,.14);color:var(--red);border-color:rgba(251,113,133,.28)}
.ynb{display:inline-flex;padding:5px 12px;border-radius:20px;cursor:pointer;font-size:11px;border:1px solid rgba(255,255,255,.07);background:transparent;color:var(--t2);margin-right:5px;transition:all .15s;user-select:none}
.ynb.y{background:rgba(52,211,153,.1);color:var(--grn);border-color:rgba(52,211,153,.24)}
.ynb.n{background:rgba(251,113,133,.1);color:var(--red);border-color:rgba(251,113,133,.24)}
#shot-zone{border:1.5px dashed rgba(139,92,246,.2);border-radius:var(--r-xl);padding:22px;text-align:center;cursor:pointer;color:var(--t3);font-size:12px;transition:all .2s}
#shot-zone:hover{border-color:rgba(139,92,246,.45);background:rgba(139,92,246,.04);color:var(--t2)}
#shot-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-top:9px}
.sthumb{position:relative;border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:rgba(12,18,35,.9);border:1px solid rgba(255,255,255,.06)}
.sthumb img{width:100%;height:100%;object-fit:cover}
.sthumb .sx{position:absolute;top:4px;right:4px;width:18px;height:18px;background:rgba(0,0,0,.8);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;cursor:pointer;color:var(--red);font-weight:700}
.psr{display:flex;align-items:center;gap:9px;margin-bottom:9px}
.psr label{width:85px;font-size:11px;color:var(--t2)}
.psr input[type=range]{flex:1;height:3px;-webkit-appearance:none;appearance:none;background:rgba(139,92,246,.2);border-radius:2px;outline:none;cursor:pointer}
.psr input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--acc);cursor:pointer;box-shadow:0 0 8px rgba(139,92,246,.5)}
.psr span{width:18px;font-size:12px;font-weight:600;color:var(--acc2);text-align:right}
#acct-panel{position:fixed;top:58px;right:16px;width:268px;background:rgba(6,10,22,.97);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);border:1px solid rgba(255,255,255,.08);border-radius:var(--r-xl);z-index:999;padding:12px;display:none;max-height:440px;overflow-y:auto;box-shadow:var(--shadow-lg)}
.ai-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:var(--r-md);cursor:pointer;transition:background .15s}
.ai-item:hover{background:rgba(var(--scene-rgb),.08)}.ai-item.on{background:rgba(var(--scene-rgb),.12)}
.a-orb{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.del-btn,.edit-btn{background:none;border:none;color:var(--t3);cursor:pointer;padding:4px 6px;border-radius:6px;font-size:12px;transition:all .15s}
.del-btn:hover{color:var(--red);background:rgba(251,113,133,.1)}.edit-btn:hover{color:var(--acc2);background:rgba(139,92,246,.1)}
.modal-bg{position:fixed;inset:0;background:rgba(4,6,14,.88);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);z-index:9990;display:none;align-items:center;justify-content:center}
.modal-box{background:rgba(8,13,28,.98);border:1px solid rgba(255,255,255,.09);border-radius:var(--r-xl);padding:26px;max-width:300px;width:90%;text-align:center;box-shadow:var(--shadow-lg),0 0 0 1px rgba(139,92,246,.1)}
.shot-modal{position:fixed;inset:0;background:rgba(4,6,14,.96);z-index:9999;padding:20px;display:none;overflow-y:auto}
.toast{position:fixed;bottom:16px;right:16px;padding:11px 18px;border-radius:var(--r-lg);font-size:12px;font-weight:600;z-index:99999;opacity:0;transform:translateX(30px);transition:opacity .3s,transform .3s;pointer-events:none;color:#fff;backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.1);box-shadow:var(--shadow-md)}
.toast.show{opacity:1;transform:translateX(0)}
.calc-box{background:rgba(139,92,246,.04);border:1px solid rgba(139,92,246,.12);border-radius:var(--r-md);padding:12px;margin-bottom:10px;display:none}
