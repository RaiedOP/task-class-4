function calcS(){const ct=trades.filter(t=>t.result!=='Pending');if(!ct.length)return null;const W=ct.filter(t=>t.result==='Win'||t.result==='Partial Win');const L=ct.filter(t=>t.result==='Loss');const wr=W.length/ct.length*100;const tot=ct.reduce((a,t)=>a+(parseFloat(t.pnl)||0),0);const gw=W.reduce((a,t)=>a+Math.max(0,parseFloat(t.pnl)||0),0);const gl=Math.abs(L.reduce((a,t)=>a+(parseFloat(t.pnl)||0),0));const pf=gl>0?gw/gl:gw>0?999:0;const rrs=ct.filter(t=>parseFloat(t.rr)>0).map(t=>parseFloat(t.rr));const avgRR=rrs.length?rrs.reduce((a,v)=>a+v,0)/rrs.length:0;const exp=tot/ct.length;const sorted=[...ct].sort((a,b)=>new Date((a.date||'')+'T'+(a.time||'00:00'))-new Date((b.date||'')+'T'+(b.time||'00:00')));let bal=0,peak=0,mxDD=0,bStr=0,tmp=0,curStr=0;sorted.forEach(t=>{const p=parseFloat(t.pnl)||0;bal+=p;if(bal>peak)peak=bal;const dd=peak-bal;if(dd>mxDD)mxDD=dd;if(t.result==='Win'){tmp++;if(tmp>bStr)bStr=tmp;}else tmp=0;});for(let i=sorted.length-1;i>=0;i--){const w=sorted[i].result==='Win'||sorted[i].result==='Partial Win';if(i===sorted.length-1)curStr=w?1:-1;else if((curStr>0&&w)||(curStr<0&&!w))curStr+=(w?1:-1);else break;}return{total:ct.length,wins:W.length,losses:L.length,wr,tot,pf,avgRR,exp,mxDD,bStr,curStr,sorted};}

function animateCounters(){setTimeout(()=>{document.querySelectorAll('.kv').forEach(el=>{const orig=el.textContent.trim();const m=orig.match(/^([+\-$€£]*)(\d+\.?\d*)(.*)/);if(!m)return;const pre=m[1],num=parseFloat(m[2]),suf=m[3];if(isNaN(num)||num<1)return;let s=null;const dur=650;const fmt=num%1===0?v=>Math.round(v):v=>v.toFixed(num<10?2:1);const step=ts=>{if(!s)s=ts;const p=Math.min((ts-s)/dur,1);const e=1-Math.pow(1-p,3);el.textContent=pre+fmt(num*e)+suf;if(p<1)requestAnimationFrame(step);else el.textContent=orig;};requestAnimationFrame(step);});},80);}
function refreshAll(){updFoot();rDash();animateCounters();}
