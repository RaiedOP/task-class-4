/* ── THREE.JS PREMIUM SCENE ──────────────────────── */
function initThreeScene(){
  if(!window.THREE){console.warn('Three.js not loaded');return;}
  const container=document.getElementById('three-bg');
  if(!container)return;
  const W=window.innerWidth,H=window.innerHeight;
  const scene=new THREE.Scene();
  scene.fog=new THREE.FogExp2(0x04060E,.006);
  const camera=new THREE.PerspectiveCamera(70,W/H,.1,2000);
  camera.position.set(0,18,90);camera.lookAt(0,0,0);
  const renderer=new THREE.WebGLRenderer({antialias:true,alpha:true});
  renderer.setSize(W,H);renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setClearColor(0x04060E,1);container.appendChild(renderer.domElement);
  function mkPts(n,spread,zRange,size,color,opacity){
    const geo=new THREE.BufferGeometry();
    const pos=new Float32Array(n*3);
    for(let i=0;i<n;i++){pos[i*3]=(Math.random()-.5)*spread;pos[i*3+1]=(Math.random()-.5)*spread*.5;pos[i*3+2]=(Math.random()-.5)*zRange;}
    geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
    return new THREE.Points(geo,new THREE.PointsMaterial({color,size,transparent:true,opacity,sizeAttenuation:true,depthWrite:false}));
  }
  const p1=mkPts(2200,500,400,.16,0xffffff,.5);
  const p2=mkPts(700,350,250,.28,0xA78BFA,.42);
  const p3=mkPts(350,250,130,.4,0x22D3EE,.32);
  scene.add(p1,p2,p3);
  const gridGeo=new THREE.PlaneGeometry(400,400,40,40);
  const gridMat=new THREE.ShaderMaterial({
    uniforms:{uColor:{value:new THREE.Color(0x8B5CF6)},uTime:{value:0},uOpacity:{value:.08}},
    vertexShader:`varying vec2 vUv;void main(){vUv=uv;gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.);}`,
    fragmentShader:`uniform vec3 uColor;uniform float uTime;uniform float uOpacity;varying vec2 vUv;void main(){vec2 grid=abs(fract(vUv*40.-.5)-.5)/fwidth(vUv*40.);float line=min(grid.x,grid.y);float alpha=(1.-min(line,1.))*uOpacity;float dist=length(vUv-.5)*2.;alpha*=(1.-smoothstep(.4,.95,dist));alpha*=(.7+.3*sin(uTime*.5+vUv.x*8.));gl_FragColor=vec4(uColor,alpha);}`,
    transparent:true,side:THREE.DoubleSide,depthWrite:false,extensions:{derivatives:true}
  });
  const grid=new THREE.Mesh(gridGeo,gridMat);
  grid.rotation.x=-Math.PI/2;grid.position.y=-22;scene.add(grid);
  const floaters=[];
  const geos=[new THREE.OctahedronGeometry(1.4,0),new THREE.TetrahedronGeometry(1.1,0),new THREE.IcosahedronGeometry(.9,0)];
  for(let i=0;i<14;i++){
    const m=new THREE.Mesh(geos[i%3],new THREE.MeshBasicMaterial({color:i%2===0?0x8B5CF6:0x22D3EE,wireframe:true,transparent:true,opacity:.055}));
    m.position.set((Math.random()-.5)*200,(Math.random()-.5)*100,(Math.random()-.5)*90-20);
    m.rotation.set(Math.random()*Math.PI,Math.random()*Math.PI,0);
    m.userData={rx:Math.random()*.004-.002,ry:Math.random()*.005-.0025,t:Math.random()*100,fy:(Math.random()-.5)*.012};
    scene.add(m);floaters.push(m);
  }
  [[0x4C1D95,-70,25,-90,180,.035],[0x0E7490,55,-18,-100,160,.028],[0x1E1B4B,0,0,-130,240,.045]].forEach(([c,x,y,z,s,o])=>{
    const m=new THREE.Mesh(new THREE.PlaneGeometry(s,s),new THREE.MeshBasicMaterial({color:c,transparent:true,opacity:o,depthWrite:false,side:THREE.DoubleSide}));
    m.position.set(x,y,z);scene.add(m);
  });
  let mx=0,my=0,tx=0,ty=0;
  const orbEl=document.getElementById('cursor-orb');
  let ox=W/2,oy=H/2,otx=W/2,oty=H/2;
  document.addEventListener('mousemove',e=>{mx=(e.clientX/W-.5)*2;my=(e.clientY/H-.5)*2;otx=e.clientX;oty=e.clientY;});
  let sceneTint={r:.534,g:.361,b:.965};
  function setPnLTint(pnl){
    const isWin=pnl>0,isLoss=pnl<0;
    const t=isWin?{r:.204,g:.831,b:.600}:isLoss?{r:.984,g:.443,b:.522}:{r:.534,g:.361,b:.965};
    const hex=isWin?'52,211,153':isLoss?'251,113,133':'139,92,246';
    if(window.gsap)gsap.to(sceneTint,{...t,duration:1.4});else Object.assign(sceneTint,t);
    document.documentElement.style.setProperty('--scene-rgb',hex);
    document.documentElement.style.setProperty('--scene-tint-soft',`rgba(${hex},.07)`);
    const sb=document.querySelector('.sb');const tb=document.querySelector('.topbar');
    if(sb)sb.style.borderRightColor=`rgba(${hex},.12)`;
    if(tb)tb.style.borderBottomColor=`rgba(${hex},.08)`;
    if(orbEl)orbEl.style.background=`radial-gradient(circle,rgba(${hex},.055) 0%,transparent 70%)`;
  }
  window.setScenePnL=setPnLTint;
  window.addEventListener('resize',()=>{const w=window.innerWidth,h=window.innerHeight;camera.aspect=w/h;camera.updateProjectionMatrix();renderer.setSize(w,h);});
  let f=0;
  function animate(){
    requestAnimationFrame(animate);f++;
    tx+=(mx-tx)*.022;ty+=(my-ty)*.022;
    camera.position.x=tx*14;camera.position.y=18-ty*8;camera.lookAt(0,0,0);
    ox+=(otx-ox)*.1;oy+=(oty-oy)*.1;
    if(orbEl){orbEl.style.left=ox+'px';orbEl.style.top=oy+'px';}
    p1.rotation.y=f*.00007;p2.rotation.y=f*.00014;p3.rotation.y=f*.00022;p1.rotation.x=f*.000025;
    floaters.forEach(fl=>{fl.rotation.x+=fl.userData.rx;fl.rotation.y+=fl.userData.ry;fl.userData.t+=.007;fl.position.y+=Math.sin(fl.userData.t)*fl.userData.fy;fl.material.opacity=.03+Math.sin(fl.userData.t*.6)*.022;});
    try{gridMat.uniforms.uTime.value=f*.016;}catch(e){}
    const c=sceneTint;renderer.setClearColor(new THREE.Color(c.r*.038,c.g*.038,c.b*.07),1);
    renderer.render(scene,camera);
  }
  animate();
  window._threeScene={scene,camera,renderer,p1,p2,p3};
}
