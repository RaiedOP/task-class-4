function autoCalc(){const inst=(document.getElementById('t-in')?.value||'').trim().toUpperCase();const dir=document.getElementById('t-di')?.value||'Buy';const en=parseFloat(document.getElementById('t-en')?.value);const sl=parseFloat(document.getElementById('t-sl')?.value);const tp=parseFloat(document.getElementById('t-tp')?.value);const lots=parseFloat(document.getElementById('t-lt')?.value);const rp=parseFloat(document.getElementById('t-rp')?.value);const aS=getAct()?.size||parseFloat(document.getElementById('t-as')?.value)||0;const cfg=iCfg(inst);let show=false;
