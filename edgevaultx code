function rAi(){
  const el=document.getElementById('ai-content');if(!el)return;
  const s=calcS();
  if(!s){el.innerHTML=`<div class="empty"><i class="ti ti-brain"></i><h3>Your coach is warming up</h3><p>Log a few trades and I'll start spotting patterns in your edge, psychology, and timing.</p></div>`;return;}

  const ct=trades.filter(t=>t.result!=='Pending');
  const hr=new Date().getHours();
  const greet=hr<12?'Good morning':hr<18?'Good afternoon':'Good evening';

  /* Session performance */
  const sm={};['London','New York','Asian','Overlap'].forEach(x=>sm[x]={w:0,t:0});
  ct.forEach(t=>{if(sm[t.session]){sm[t.session].t++;if(t.result==='Win')sm[t.session].w++;}});
  const bestSess=Object.entries(sm).filter(([,v])=>v.t>=2).sort((a,b)=>(b[1].w/b[1].t)-(a[1].w/a[1].t))[0];

  /* Violations */
  const vCount={};ct.forEach(t=>(t.violations||[]).forEach(v=>{vCount[v]=(vCount[v]||0)+1;}));
  const topV=Object.entries(vCount).sort((a,b)=>b[1]-a[1])[0];

  /* Day of week violation pattern */
  const dowV={};ct.forEach(t=>{if(!t.date)return;const d=new Date(t.date+'T00:00');const dow=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];if((t.violations||[]).length){dowV[dow]=(dowV[dow]||0)+1;}});
  const worstDow=Object.entries(dowV).sort((a,b)=>b[1]-a[1])[0];

  /* Confidence trend (first half vs second half) */
  const withConf=ct.filter(t=>t.confidence!==undefined&&t.confidence!=='');
  let confTrend=null;
  if(withConf.length>=4){
    const half=Math.floor(withConf.length/2);
    const a=withConf.slice(0,half).reduce((s,t)=>s+(+t.confidence||0),0)/half;
    const b=withConf.slice(half).reduce((s,t)=>s+(+t.confidence||0),0)/(withConf.length-half);
    confTrend=Math.round((b-a)/Math.max(a,1)*100);
  }

  /* Recommended risk based on recent streak */
  const recentLoss=s.curStr<0;
  const recRisk=recentLoss?Math.max(0.25,1-Math.abs(s.curStr)*0.25):s.curStr>=2?1.5:1;

  const insights=[];
  insights.push({icon:'ti-sun',color:'var(--amb)',text:`${greet}. Your overall win rate sits at <b>${s.wr.toFixed(0)}%</b> across ${s.total} closed trades.`});
  if(bestSess)insights.push({icon:'ti-clock',color:'var(--cyn)',text:`<b>${bestSess[0]}</b> session is currently your strongest, with a ${Math.round(bestSess[1].w/bestSess[1].t*100)}% win rate.`});
  if(topV)insights.push({icon:'ti-alert-triangle',color:'var(--red)',text:`You've logged <b>${topV[0]}</b> as a violation ${topV[1]} time${topV[1]>1?'s':''} — worth watching closely.`});
  if(worstDow)insights.push({icon:'ti-calendar',color:'var(--amb)',text:`You break your rules most often on <b>${worstDow[0]}days</b>.`});
  if(confTrend!==null)insights.push({icon:confTrend>=0?'ti-trending-up':'ti-trending-down',color:confTrend>=0?'var(--grn)':'var(--red)',text:`Confidence has ${confTrend>=0?'improved':'declined'} by <b>${Math.abs(confTrend)}%</b> across your recent trades.`});
  if(s.curStr<=-2)insights.push({icon:'ti-shield',color:'var(--red)',text:`You're on a ${Math.abs(s.curStr)}-loss streak. Consider stepping back or reducing size before your next trade.`});
  else if(s.curStr>=3)insights.push({icon:'ti-flame',color:'var(--grn)',text:`You're on a ${s.curStr}-win streak. Stay disciplined — don't let confidence turn into overconfidence.`});

  el.innerHTML=`
    <div class="card" style="background:linear-gradient(135deg,rgba(139,92,246,.08),rgba(34,211,238,.04));padding:22px;margin-bottom:16px">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px">
        <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--acc),var(--cyn));display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 20px rgba(139,92,246,.4)"><i class="ti ti-brain" style="font-size:20px;color:#fff"></i></div>
        <div>
          <div style="font-family:var(--font-display);font-weight:700;font-size:15px;color:var(--txt)">EdgeVault Coach</div>
          <div style="font-size:11px;color:var(--t3)">Personalized insights from your trading data</div>
        </div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px">
      ${insights.map(i=>`<div class="card" style="padding:14px 18px;display:flex;align-items:flex-start;gap:14px;margin-bottom:0">
        <div style="width:32px;height:32px;border-radius:10px;background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;flex-shrink:0"><i class="ti ${i.icon}" style="font-size:16px;color:${i.color}"></i></div>
        <div style="font-size:13px;color:var(--t2);line-height:1.6;padding-top:4px">${i.text}</div>
      </div>`).join('')}
    </div>
    <div class="card" style="padding:18px;background:rgba(${recentLoss?'251,113,133':'52,211,153'},.05);border-color:rgba(${recentLoss?'251,113,133':'52,211,153'},.18)">
      <div style="font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;font-weight:600">Recommended Risk Today</div>
      <div style="font-family:var(--font-display);font-size:30px;font-weight:800;color:${recentLoss?'var(--red)':'var(--grn)'}">${recRisk}%</div>
      <div style="font-size:12px;color:var(--t3);margin-top:6px">${recentLoss?'Reduced size recommended after recent losses — protect your capital.':s.curStr>=2?'In good form — stay within your normal risk parameters.':'Standard risk based on your current performance.'}</div>
    </div>`;
